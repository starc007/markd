{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
