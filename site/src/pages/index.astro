---
import Layout from "../layouts/Layout.astro";

// Release coordinates — kept in sync with scripts/release.sh output.
const VERSION = "0.1.1";
const DMG = "/downloads/Markd_0.1.1_aarch64.dmg";
const GITHUB = "https://github.com/usemarkd/markd"; // TODO: point at the real repo

const features = [
  {
    title: "Plain files, real folders",
    body: "Every note is a .md file on your disk. No database, no proprietary format, no lock-in. Open the folder in anything.",
  },
  {
    title: "Local-first, always",
    body: "Nothing leaves your machine. Rust owns the filesystem; the app is just the window. Your notes work offline, forever.",
  },
  {
    title: "Instant search",
    body: "Title and content, ranked, in milliseconds. Title matches surface first so the note you meant is always at the top.",
  },
  {
    title: "Tabs & page links",
    body: "Open notes in tabs; link between them with [[wiki]] syntax that stores as clean markdown. Switching tabs never reparses.",
  },
  {
    title: "Frontmatter, rendered",
    body: "YAML from web clippers or any tool is preserved verbatim and shown as a tidy properties panel above the note.",
  },
  {
    title: "Silent auto-update",
    body: "Signed updates delivered straight to the app. No app store, no manual downloads after the first — it just stays current.",
  },
];
---

<Layout>
  <!-- Nav -->
  <header class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2 text-ink">
      <span class="inline-grid h-6 w-6 place-items-center rounded-[6px] bg-invert font-mono text-[13px] font-semibold text-invert-ink">M</span>
      <span class="text-[15px] font-semibold tracking-tight">Markd</span>
    </a>
    <nav class="flex items-center gap-1.5 text-[13px]">
      <a href={GITHUB} class="rounded-lg px-3 py-1.5 text-muted transition-colors hover:bg-hover hover:text-ink">GitHub</a>
      <a href={DMG} class="rounded-lg bg-invert px-3.5 py-1.5 font-medium text-invert-ink transition-opacity hover:opacity-90">Download</a>
    </nav>
  </header>

  <main class="mx-auto max-w-5xl px-6">
    <!-- Hero -->
    <section class="pt-16 pb-14 md:pt-24 md:pb-20">
      <p class="rise font-mono text-[12px] uppercase tracking-[0.18em] text-faint" style="animation-delay: 0ms">
        Local-first markdown · macOS
      </p>
      <h1 class="rise mt-5 max-w-2xl text-[40px] font-semibold leading-[1.05] tracking-[-0.03em] text-ink md:text-[58px]" style="animation-delay: 60ms">
        Notes that live in
        <span class="text-faint">your</span> folder.
      </h1>
      <p class="rise mt-6 max-w-xl text-[16px] leading-relaxed text-muted md:text-[17px]" style="animation-delay: 120ms">
        Markd is a fast, monochrome markdown editor for macOS. Plain <code class="font-mono text-[0.9em] text-ink">.md</code> files in a
        folder you own — portable, offline, yours.
      </p>

      <div class="rise mt-9 flex flex-wrap items-center gap-4" style="animation-delay: 180ms">
        <a
          href={DMG}
          class="group inline-flex items-center gap-2.5 rounded-xl bg-invert px-5 py-3 text-[15px] font-medium text-invert-ink transition-transform duration-150 hover:-translate-y-0.5"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16.365 1.43c0 1.14-.42 2.2-1.12 2.98-.75.85-2 1.5-3.02 1.42-.13-1.1.42-2.27 1.08-3 .74-.82 2.05-1.42 3.06-1.4zM20.5 17.02c-.55 1.27-.81 1.83-1.52 2.95-.99 1.56-2.38 3.5-4.1 3.51-1.53.02-1.92-1-4-.99-2.07.01-2.5 1.01-4.03.99-1.72-.02-3.04-1.77-4.03-3.33-2.77-4.37-3.06-9.5-1.35-12.22 1.21-1.94 3.13-3.08 4.93-3.08 1.84 0 3 1.01 4.51 1.01 1.47 0 2.37-1.01 4.5-1.01 1.61 0 3.32.88 4.53 2.4-3.98 2.18-3.33 7.86.09 9.79z"/>
          </svg>
          Download for macOS
        </a>
        <div class="text-[13px] leading-tight text-muted">
          <div>Free · Apple Silicon</div>
          <div class="text-faint">Version {VERSION} · macOS 12+</div>
        </div>
      </div>
    </section>

    <!-- App mock — the signature Markd look, rebuilt in CSS -->
    <section class="rise pb-20" style="animation-delay: 260ms">
      <div class="overflow-hidden rounded-2xl border border-line bg-panel shadow-[0_30px_80px_-40px_rgba(0,0,0,0.45)]">
        <!-- window chrome -->
        <div class="flex items-center gap-2 border-b border-line bg-sunken px-4 py-2.5">
          <span class="h-3 w-3 rounded-full border border-line-soft bg-bg"></span>
          <span class="h-3 w-3 rounded-full border border-line-soft bg-bg"></span>
          <span class="h-3 w-3 rounded-full border border-line-soft bg-bg"></span>
          <span class="ml-3 font-mono text-[11px] text-faint">markd — vault</span>
        </div>

        <div class="grid grid-cols-[168px_1fr] md:grid-cols-[200px_1fr]">
          <!-- sidebar -->
          <aside class="hidden flex-col gap-1 border-r border-line p-3 sm:flex">
            <div class="mb-2 flex items-center gap-2 rounded-lg bg-bg px-2.5 py-1.5 text-[12px] text-faint">
              <span class="h-1.5 w-1.5 rounded-full bg-faint"></span> Search
            </div>
            {["Inbox", "Journal"].map((n) => (
              <div class="rounded-lg px-2.5 py-1.5 text-[13px] text-muted">{n}</div>
            ))}
            <div class="rounded-lg bg-invert px-2.5 py-1.5 text-[13px] font-medium text-invert-ink">Release notes</div>
            {["Reading list", "Ideas", "meeting-2024"].map((n) => (
              <div class="rounded-lg px-2.5 py-1.5 text-[13px] text-muted">{n}</div>
            ))}
          </aside>

          <!-- editor -->
          <div class="min-h-[320px] p-6 md:p-8">
            <div class="mb-4 flex items-center gap-1.5 font-mono text-[11px] text-faint">
              <span>notes</span><span>/</span><span class="text-muted">release-notes.md</span>
            </div>
            <h2 class="text-[26px] font-semibold tracking-tight text-ink">Release notes</h2>

            <!-- properties panel -->
            <div class="mt-4 flex flex-wrap gap-2">
              {["v0.1.1", "macOS", "shipped"].map((t) => (
                <span class="rounded-md border border-line bg-bg px-2 py-0.5 font-mono text-[11px] text-muted">{t}</span>
              ))}
            </div>

            <!-- faux content lines -->
            <div class="mt-6 space-y-3">
              <div class="h-2.5 w-[92%] rounded bg-line"></div>
              <div class="h-2.5 w-[78%] rounded bg-line"></div>
              <div class="h-2.5 w-[85%] rounded bg-line-soft"></div>
              <div class="mt-5 flex items-center gap-2.5">
                <span class="grid h-4 w-4 place-items-center rounded border border-faint bg-invert text-invert-ink">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                </span>
                <div class="h-2.5 w-[46%] rounded bg-line"></div>
              </div>
              <div class="flex items-center gap-2.5">
                <span class="h-4 w-4 rounded border border-line"></span>
                <div class="h-2.5 w-[54%] rounded bg-line"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="border-t border-line py-16 md:py-20">
      <h2 class="max-w-lg text-[26px] font-semibold tracking-tight text-ink md:text-[32px]">
        A notes app that gets out of the way.
      </h2>
      <div class="mt-10 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="bg-bg p-6 transition-colors hover:bg-panel">
            <h3 class="text-[15px] font-semibold text-ink">{f.title}</h3>
            <p class="mt-2 text-[13.5px] leading-relaxed text-muted">{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="border-t border-line py-16 text-center md:py-24">
      <h2 class="mx-auto max-w-lg text-[28px] font-semibold tracking-tight text-ink md:text-[36px]">
        Your notes, on your disk.
      </h2>
      <p class="mx-auto mt-4 max-w-md text-[15px] text-muted">
        No account. No cloud. No subscription. Download it and start writing.
      </p>
      <a
        href={DMG}
        class="mt-8 inline-flex items-center gap-2.5 rounded-xl bg-invert px-5 py-3 text-[15px] font-medium text-invert-ink transition-transform duration-150 hover:-translate-y-0.5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.365 1.43c0 1.14-.42 2.2-1.12 2.98-.75.85-2 1.5-3.02 1.42-.13-1.1.42-2.27 1.08-3 .74-.82 2.05-1.42 3.06-1.4zM20.5 17.02c-.55 1.27-.81 1.83-1.52 2.95-.99 1.56-2.38 3.5-4.1 3.51-1.53.02-1.92-1-4-.99-2.07.01-2.5 1.01-4.03.99-1.72-.02-3.04-1.77-4.03-3.33-2.77-4.37-3.06-9.5-1.35-12.22 1.21-1.94 3.13-3.08 4.93-3.08 1.84 0 3 1.01 4.51 1.01 1.47 0 2.37-1.01 4.5-1.01 1.61 0 3.32.88 4.53 2.4-3.98 2.18-3.33 7.86.09 9.79z"/>
        </svg>
        Download for macOS
      </a>
    </section>
  </main>

  <!-- Footer -->
  <footer class="mx-auto max-w-5xl px-6 py-10">
    <div class="flex flex-col items-start justify-between gap-4 border-t border-line pt-6 text-[13px] text-faint sm:flex-row sm:items-center">
      <div class="flex items-center gap-2">
        <span class="inline-grid h-5 w-5 place-items-center rounded-[5px] bg-invert font-mono text-[11px] font-semibold text-invert-ink">M</span>
        <span class="text-muted">Markd · v{VERSION}</span>
      </div>
      <div class="flex items-center gap-5">
        <a href={GITHUB} class="transition-colors hover:text-ink">GitHub</a>
        <a href={GITHUB + "/blob/main/LICENSE"} class="transition-colors hover:text-ink">MIT License</a>
        <span>Your notes stay on your disk.</span>
      </div>
    </div>
  </footer>
</Layout>
