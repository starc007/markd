---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Markd — local-first markdown notes for macOS",
  description = "A local-first markdown notes app for macOS. Plain files in a folder you own. Monochrome, fast, no lock-in.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbfbfa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://usemarkd.app" />
    <link rel="canonical" href="https://usemarkd.app" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
