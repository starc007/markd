# Update manifest must never be stale — clients poll it for new versions.
/updates/latest.json
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/json

# Signed update bundle — immutable per release, cache hard.
/updates/*.tar.gz
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/gzip

# DMG installer — immutable per release.
/downloads/*.dmg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/x-apple-diskimage
